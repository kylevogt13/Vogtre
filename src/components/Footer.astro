---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="/">
          <img src="/images/logo.png" alt="The Vogt Real Estate Group" style="height: 60px; width: auto; margin-bottom: 1rem;" />
        </a>
        <p>13098 Apple Road</p>
        <p>Wilton, California 95693</p>
        <p style="margin-top: 0.75rem;">
          <a href="tel:9168014002">(916) 801-4002</a>
        </p>
        <p>
          <a href="mailto:thevogts@thevogtregroup.com">thevogts@thevogtregroup.com</a>
        </p>
        <div style="margin-top: 1rem; display: flex; gap: 1rem;">
          <a href="https://facebook.com/Vogtrealestate/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" style="color: rgba(255,255,255,0.5); transition: color 0.2s;">
            Facebook
          </a>
          <a href="https://instagram.com/kylevogt1/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" style="color: rgba(255,255,255,0.5); transition: color 0.2s;">
            Instagram
          </a>
        </div>
      </div>

      <div class="footer__col">
        <h5>Buy & Sell</h5>
        <ul>
          <li><a href="/search">Search Homes</a></li>
          <li><a href="/buyers-guide">Buyer's Guide</a></li>
          <li><a href="/sellers-guide">Seller's Guide</a></li>
          <li><a href="/communities">Communities</a></li>
          <li><a href="/home-value">Home Valuation</a></li>
          <li><a href="/pre-qualified">Get Pre-Qualified</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h5>Company</h5>
        <ul>
          <li><a href="/team">Our Team</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/testimonials">Testimonials</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h5>Resources</h5>
        <ul>
          <li><a href="/join-our-team">Join Our Team</a></li>
          <li><a href="/refer-a-friend">Refer a Friend</a></li>
          <li><a href="/articles">News & Articles</a></li>
