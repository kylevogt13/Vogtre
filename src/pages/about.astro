---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="About Us | The Vogt Real Estate Group" description="Learn about The Vogt Real Estate Group — a multigenerational team born and raised in the Greater Sacramento Region, guiding families home with trust and heart.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">Our Story</span>
      <h1>About Us</h1>
      <p>
        A proud multigenerational team, born and raised in the Greater
        Sacramento Region — guiding families home with trust, knowledge, and heart.
      </p>
    </div>
  </section>

  <section class="about">
    <div class="container">
      <div class="about__grid">
        <div class="about__image fade-in">
          <img
            src="/images/vogt-group-2.jpg"
            alt="The Vogt Real Estate Group"
            loading="lazy"
          />
          <div class="about__image-accent"></div>
        </div>

        <div class="about__text fade-in">
          <span class="overline">Who We Are</span>
          <h2>Real Estate With Heart</h2>
          <p>
            We know buying or selling a home is more than a transaction — it's a life
            decision. Our mission is to guide you with trust, knowledge, and heart in
            every step of your real estate journey.
          </p>
          <p>
            At The Vogt Real Estate Group, we are a proud multigenerational team,
            born and raised in the Greater Sacramento Region. We bring together
            the wisdom that comes with life and business experience, along with
            the fresh energy and vision needed to embrace the future.
          </p>
          <p>
            Education and growth are at the heart of what we do. We believe real estate
            is more than just a transaction — it's a milestone, an investment, and a
            pathway to your future.
          </p>
          <p>
            Because we know this community inside and out, we're passionate about being
            your trusted resource for all things real estate — whether that means finding
            your dream home, guiding you through selling with confidence, or helping you
            make smart investments.
          </p>
          <p>
            With The Vogt Real Estate Group, you don't just have an agent — you
            have a dedicated team working for you with heart, commitment, and vision.
          </p>
          <a href="/team" class="btn btn-primary">Meet Our Team</a>
          <div class="about__license">DRE License #02144449</div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Ready to Get Started?</h2>
      <p>
        Let's talk about your real estate goals. Our team is here to help
        you make your next move with confidence.
      </p>
      <a href="/contact" class="btn btn-outline">Contact Us Today</a>
    </div>
  </section>

  <Footer />
</BaseLayout>
