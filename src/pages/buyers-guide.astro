---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Buyer's Guide | The Vogt Real Estate Group" description="A step-by-step guide to buying a home in Sacramento. Expert tips from The Vogt Real Estate Group.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">A Step-by-Step Guide</span>
      <h1>Buying With Vogt Real Estate Group</h1>
    </div>
  </section>

  <section>
    <div class="container" style="max-width: 780px;">
      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 1</span>
        <h3 style="margin: 0.75rem 0 1rem;">Analyze Your Situation</h3>
        <p style="color: var(--c-slate);">
          Determine readiness to buy by discussing your goals and needs. Communication
          is essential throughout the journey to home ownership.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 2</span>
        <h3 style="margin: 0.75rem 0 1rem;">Finance &amp; Understand the Numbers</h3>
        <p style="color: var(--c-slate);">
          Organize finances with help from recommended lenders. Credit review, determine
          affordable price ranges, and obtain formal pre-approval.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 3</span>
        <h3 style="margin: 0.75rem 0 1rem;">Shop</h3>
        <p style="color: var(--c-slate);">
          Create a wish list of desired home and community features. Your agent matches
          priorities with budget constraints using local expertise.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 4</span>
        <h3 style="margin: 0.75rem 0 1rem;">Offer &amp; Negotiate</h3>
        <p style="color: var(--c-slate);">
          Submit a data-driven offer based on comparative market analysis. Negotiate
          contingencies and contract terms effectively.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 5</span>
        <h3 style="margin: 0.75rem 0 1rem;">Offer Acceptance</h3>
        <p style="color: var(--c-slate);">
          Once accepted, title and escrow processes begin, typically lasting 17-25 days
          before closing. Lender prepares loan disclosures.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 6</span>
        <h3 style="margin: 0.75rem 0 1rem;">Title and Escrow</h3>
        <p style="color: var(--c-slate);">
          Title company handles closing and researches property title, liens, and ownership
          chain. Transaction timeline typically 17-25 days.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 7</span>
        <h3 style="margin: 0.75rem 0 1rem;">Seller Disclosures, Lender Documents &amp; Appraisal</h3>
        <p style="color: var(--c-slate);">
          Review seller disclosures, sign loan documents, and order appraisals (approximately
          $600-$800). Obtain homeowners insurance quotes.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 8</span>
        <h3 style="margin: 0.75rem 0 1rem;">Inspections</h3>
        <p style="color: var(--c-slate);">
          Schedule property inspections within days of offer acceptance. Inspections cost
          about $600 and up and help identify issues for negotiation.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 9</span>
        <h3 style="margin: 0.75rem 0 1rem;">Final Loan Approval &amp; Signing</h3>
        <p style="color: var(--c-slate);">
          Approximately one week before closing, sign final documents and closing disclosure
          outlining all costs. Payment typically via cashier's check or wire transfer.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 10</span>
        <h3 style="margin: 0.75rem 0 1rem;">Celebrate!</h3>
        <p style="color: var(--c-slate);">
          Collect keys after title confirms close of escrow. Contact utility companies
          and update mailing address.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <p style="color: var(--c-slate); font-style: italic;">
          After closing, your lender and agent remain available for future assistance.
        </p>
      </div>

      <div class="cta-band fade-in" style="text-align: center; padding-top: 2rem;">
        <a href="/search" class="btn btn-primary">Start Searching Homes</a>
        <span style="display: inline-block; margin: 0 1rem; color: var(--c-muted);">or</span>
        <a href="/contact" class="btn btn-outline">Talk to Our Team</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
