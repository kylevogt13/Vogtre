---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Buyer's Guide | The Vogt Real Estate Group">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">For Buyers</span>
      <h1>Buyer's Guide</h1>
      <p>
        Your step-by-step guide to purchasing a home in the Sacramento region.
        We'll walk you through every stage of the process.
      </p>
    </div>
  </section>

  <section>
    <div class="container" style="max-width: 780px;">
      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 1</span>
        <h3 style="margin: 0.75rem 0 1rem;">Get Pre-Qualified</h3>
        <p style="color: var(--c-slate);">
          Before you start looking at homes, it's important to know what you can afford.
          A pre-qualification from a trusted lender gives you buying power and shows sellers
          you're serious. We can connect you with mortgage professionals who specialize
          in the Sacramento market.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 2</span>
        <h3 style="margin: 0.75rem 0 1rem;">Define Your Search</h3>
        <p style="color: var(--c-slate);">
          Location, size, features, schools — we'll help you identify your priorities
          and set up personalized search alerts so you never miss a new listing that
          matches your criteria.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 3</span>
        <h3 style="margin: 0.75rem 0 1rem;">Tour & Evaluate</h3>
        <p style="color: var(--c-slate);">
          We'll schedule showings, walk through properties with you, and give you
          honest assessments based on our 35+ years of market experience. Our goal
          is to find a home that fits both your lifestyle and your budget.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 4</span>
        <h3 style="margin: 0.75rem 0 1rem;">Make an Offer & Negotiate</h3>
        <p style="color: var(--c-slate);">
          When you find the right property, we'll craft a competitive offer,
          negotiate on your behalf, and guide you through inspections, appraisals,
          and contingencies with skill and transparency.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 5</span>
        <h3 style="margin: 0.75rem 0 1rem;">Close & Get Your Keys</h3>
        <p style="color: var(--c-slate);">
          From escrow to final walkthrough, we manage every detail so closing
          day is smooth and stress-free. Welcome home.
        </p>
      </div>

      <div class="fade-in" style="text-align: center; padding-top: 2rem;">
        <a href="/search" class="btn btn-primary">Start Searching Homes</a>
        <span style="display: inline-block; margin: 0 1rem; color: var(--c-muted);">or</span>
        <a href="/contact" class="btn btn-outline">Talk to Our Team</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
