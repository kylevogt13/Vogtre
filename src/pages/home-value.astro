---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="What's Your Home Worth? | The Vogt Real Estate Group" description="Get a free home valuation from The Vogt Real Estate Group. Discover what your Sacramento area home is worth today.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">Home Valuation</span>
      <h1>Discover the Value of Your Home</h1>
      <p>
        Get a free, no-obligation estimate of your home's current market value
        from our experienced team.
      </p>
    </div>
  </section>

  <section class="home-value">
    <div class="container">
      <div class="home-value__grid">
        <div class="home-value__content fade-in">
          <span class="overline">Free Analysis</span>
          <h2>Get a Personalized Market Analysis</h2>
          <p>
            Whether you're thinking about selling, refinancing, or simply curious
            about your home's worth, we're here to help. Our team will provide a
            personalized comparative market analysis based on recent sales in your
            neighborhood, current market trends, and the unique features of your
            property.
          </p>
          <p>
            Fill out the form and a member of our team will be in touch with a
            detailed report — completely free and with no obligation.
          </p>
        </div>

        <div class="home-value__form fade-in">
          <h3>Request Your Free Valuation</h3>
          <form name="home-value" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="home-value" />
            <p class="sr-only">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="form-group">
              <label for="fullName">Full Name *</label>
              <input type="text" id="fullName" name="fullName" required />
            </div>

            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="phone">Phone *</label>
              <input type="tel" id="phone" name="phone" required />
            </div>

            <div class="form-group">
              <label for="address">Property Address *</label>
              <input type="text" id="address" name="address" required placeholder="123 Main St" />
            </div>

            <div class="form-group">
              <label for="city">City *</label>
              <input type="text" id="city" name="city" required placeholder="e.g. Sacramento" />
            </div>

            <div class="form-group">
              <label for="comments">Comments</label>
              <textarea id="comments" name="comments" rows="4" placeholder="Any details about your property or timeline..."></textarea>
            </div>

            <p class="form-consent">
              By submitting this form you consent to receive communications from
              The Vogt Real Estate Group.
            </p>

            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Get My Home Value
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Want More Information?</h2>
      <p>
        Contact us directly to discuss your property, the local market, or
        anything else on your mind.
      </p>
      <a href="/contact" class="btn btn-outline">Contact Us Today</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .home-value {
    padding: clamp(3rem, 6vw, 6rem) 0;
  }

  .home-value__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .home-value__content h2 {
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .home-value__content p {
    color: var(--c-slate);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .home-value__form h3 {
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 600;
    color: var(--c-espresso);
    font-size: 0.95rem;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    background: #fff;
    color: var(--c-espresso);
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--c-gold);
  }

  .form-consent {
    font-size: 0.8rem;
    color: var(--c-slate);
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .home-value__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
