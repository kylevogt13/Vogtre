---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Join Our Team | The Vogt Real Estate Group" description="Join The Vogt Real Estate Group — comprehensive training, cutting-edge tools, and a supportive team environment in Sacramento.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">Careers</span>
      <h1>Join Our Team</h1>
      <p>
        Discover growth opportunities and build a thriving career with a team
        that invests in your success.
      </p>
    </div>
  </section>

  <section class="join-team">
    <div class="container">
      <div class="join-team__grid">
        <div class="join-team__content fade-in">
          <span class="overline">Why Vogt</span>
          <h2>Work With Us</h2>
          <p>
            Join Vogt Real Estate Group, where your growth and success are our top
            priority! We offer comprehensive training, cutting-edge tools, and a
            supportive team environment that empowers you to reach your full
            potential. With access to a diverse portfolio of properties and a strong
            network, you'll have everything you need to thrive in today's
            competitive market. If you're passionate about real estate and ready to
            make a difference for your clients, we'd love to welcome you to our
            team!
          </p>
          <div class="join-team__image fade-in">
            <img
              src="/images/join-team.png"
              alt="Join The Vogt Real Estate Group"
              loading="lazy"
            />
          </div>
        </div>

        <div class="join-team__form fade-in">
          <h3>Apply Today</h3>
          <form name="join-team" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="join-team" />
            <p class="sr-only">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="form-row">
              <div class="form-group">
                <label for="firstName">First Name *</label>
                <input type="text" id="firstName" name="firstName" required />
              </div>
              <div class="form-group">
                <label for="lastName">Last Name *</label>
                <input type="text" id="lastName" name="lastName" required />
              </div>
            </div>

            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="phone">Phone *</label>
              <input type="tel" id="phone" name="phone" required />
            </div>

            <div class="form-group">
              <label for="experience">How long have you been an agent?</label>
              <input type="text" id="experience" name="experience" placeholder="e.g. 3 years" />
            </div>

            <div class="form-group">
              <label for="transactions">Transactions closed in last 24 months?</label>
              <input type="text" id="transactions" name="transactions" placeholder="e.g. 12" />
            </div>

            <div class="form-group">
              <label for="comments">Comments</label>
              <textarea id="comments" name="comments" rows="4"></textarea>
            </div>

            <p class="form-consent">
              By submitting this form you consent to receive communications from
              The Vogt Real Estate Group.
            </p>

            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Submit Application
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Have Questions?</h2>
      <p>
        Reach out to learn more about career opportunities with The Vogt Real
        Estate Group.
      </p>
      <a href="/contact" class="btn btn-outline">Contact Us Today</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .join-team {
    padding: clamp(3rem, 6vw, 6rem) 0;
  }

  .join-team__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .join-team__content h2 {
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .join-team__content p {
    color: var(--c-slate);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .join-team__image img {
    width: 100%;
    border-radius: 12px;
  }

  .join-team__form h3 {
    margin-bottom: 1.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 600;
    color: var(--c-espresso);
    font-size: 0.95rem;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    background: #fff;
    color: var(--c-espresso);
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--c-gold);
  }

  .form-consent {
    font-size: 0.8rem;
    color: var(--c-slate);
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .join-team__grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
