---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Get Pre-Qualified | The Vogt Real Estate Group" description="Get pre-qualified for a home loan. The Vogt Real Estate Group connects you with trusted lending partners in Sacramento.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">Financing</span>
      <h1>Get Pre-Qualified</h1>
      <p>
        Take the first step toward homeownership — we'll connect you with
        trusted lending partners to get you pre-qualified.
      </p>
    </div>
  </section>

  <section class="pre-qualified">
    <div class="container">
      <div class="pre-qualified__grid">
        <div class="pre-qualified__content fade-in">
          <span class="overline">First Steps</span>
          <h2>Start Your Home Buying Journey</h2>
          <p>
            Getting pre-qualified is the first and most important step in the home
            buying process. A pre-qualification letter shows sellers you're a
            serious buyer and gives you a clear picture of your budget — so you
            can shop with confidence.
          </p>
          <p>
            At The Vogt Real Estate Group, we've partnered with trusted local
            lenders who offer competitive rates, personalized service, and a
            smooth approval process. Fill out the form below and we'll connect you
            with the right lending partner for your situation.
          </p>
        </div>

        <div class="pre-qualified__form fade-in">
          <h3>Get Started</h3>
          <form name="pre-qualified" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="pre-qualified" />
            <p class="sr-only">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="form-group">
              <label for="fullName">Full Name *</label>
              <input type="text" id="fullName" name="fullName" required />
            </div>

            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required />
            </div>

            <div class="form-group">
              <label for="phone">Phone *</label>
              <input type="tel" id="phone" name="phone" required />
            </div>

            <div class="form-group">
              <label for="priceRange">Desired Purchase Price Range</label>
              <select id="priceRange" name="priceRange">
                <option value="">Select one...</option>
                <option value="under-300k">Under $300K</option>
                <option value="300k-500k">$300K – $500K</option>
                <option value="500k-750k">$500K – $750K</option>
                <option value="750k-1m">$750K – $1M</option>
                <option value="1m-plus">$1M+</option>
              </select>
            </div>

            <div class="form-group">
              <label>First Time Buyer?</label>
              <div class="radio-group">
                <label class="radio-label">
                  <input type="radio" name="firstTimeBuyer" value="yes" />
                  <span>Yes</span>
                </label>
                <label class="radio-label">
                  <input type="radio" name="firstTimeBuyer" value="no" />
                  <span>No</span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label for="comments">Comments</label>
              <textarea id="comments" name="comments" rows="4" placeholder="Any additional details about your situation..."></textarea>
            </div>

            <p class="form-consent">
              By submitting this form you consent to receive communications from
              The Vogt Real Estate Group.
            </p>

            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Get Pre-Qualified
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Have Financing Questions?</h2>
      <p>
        Our team is happy to walk you through the process and answer any
        questions about getting pre-qualified.
      </p>
      <a href="/contact" class="btn btn-outline">Contact Us Today</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .pre-qualified {
    padding: clamp(3rem, 6vw, 6rem) 0;
  }

  .pre-qualified__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .pre-qualified__content h2 {
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .pre-qualified__content p {
    color: var(--c-slate);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .pre-qualified__form h3 {
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 600;
    color: var(--c-espresso);
    font-size: 0.95rem;
  }

  .form-group input[type="text"],
  .form-group input[type="email"],
  .form-group input[type="tel"],
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    background: #fff;
    color: var(--c-espresso);
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--c-gold);
  }

  .radio-group {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.25rem;
  }

  .radio-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 400;
    cursor: pointer;
  }

  .radio-label input[type="radio"] {
    width: auto;
    accent-color: var(--c-gold);
  }

  .form-consent {
    font-size: 0.8rem;
    color: var(--c-slate);
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .pre-qualified__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
