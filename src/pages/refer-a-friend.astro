---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Refer a Friend | The Vogt Real Estate Group" description="Know someone buying or selling a home? Refer them to The Vogt Real Estate Group.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">Referrals</span>
      <h1>Refer a Friend</h1>
      <p>
        Know someone buying or selling a home? Help your friends and family
        get the trusted guidance they deserve.
      </p>
    </div>
  </section>

  <section class="referral">
    <div class="container">
      <div class="referral__grid">
        <div class="referral__content fade-in">
          <span class="overline">Spread the Word</span>
          <h2>Your Referrals Mean the World to Us</h2>
          <p>
            A referral is the highest compliment we can receive. When you refer a
            friend or family member to The Vogt Real Estate Group, you're helping
            them connect with a team that will treat their real estate goals with
            the same care, dedication, and expertise you experienced.
          </p>
          <p>
            Simply fill out the form and we'll reach out to your referral
            personally — no pressure, just a friendly conversation about how we
            can help.
          </p>
        </div>

        <div class="referral__form fade-in">
          <h3>Referral Details</h3>
          <form name="referral" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="referral" />
            <p class="sr-only">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>

            <div class="form-group">
              <label for="yourName">Your Name *</label>
              <input type="text" id="yourName" name="yourName" required />
            </div>

            <div class="form-group">
              <label for="yourEmail">Your Email *</label>
              <input type="email" id="yourEmail" name="yourEmail" required />
            </div>

            <div class="form-group">
              <label for="yourPhone">Your Phone</label>
              <input type="tel" id="yourPhone" name="yourPhone" />
            </div>

            <hr class="form-divider" />

            <div class="form-group">
              <label for="friendName">Friend's Name *</label>
              <input type="text" id="friendName" name="friendName" required />
            </div>

            <div class="form-group">
              <label for="friendPhone">Friend's Phone *</label>
              <input type="tel" id="friendPhone" name="friendPhone" required />
            </div>

            <div class="form-group">
              <label for="friendEmail">Friend's Email</label>
              <input type="email" id="friendEmail" name="friendEmail" />
            </div>

            <div class="form-group">
              <label for="notes">Notes</label>
              <textarea id="notes" name="notes" rows="4" placeholder="Any details about your friend's situation..."></textarea>
            </div>

            <p class="form-consent">
              By submitting this form you consent to receive communications from
              The Vogt Real Estate Group.
            </p>

            <button type="submit" class="btn btn-primary" style="width: 100%; justify-content: center;">
              Submit Referral
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Want to Talk to Us Directly?</h2>
      <p>
        We're always happy to hear from you. Reach out anytime to discuss
        how we can help your friends and family.
      </p>
      <a href="/contact" class="btn btn-outline">Contact Us Today</a>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .referral {
    padding: clamp(3rem, 6vw, 6rem) 0;
  }

  .referral__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .referral__content h2 {
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .referral__content p {
    color: var(--c-slate);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .referral__form h3 {
    margin-bottom: 1.5rem;
  }

  .form-divider {
    border: none;
    border-top: 1px solid #eee;
    margin: 1.5rem 0;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: 600;
    color: var(--c-espresso);
    font-size: 0.95rem;
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-family: inherit;
    font-size: 1rem;
    background: #fff;
    color: var(--c-espresso);
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--c-gold);
  }

  .form-consent {
    font-size: 0.8rem;
    color: var(--c-slate);
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .referral__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
