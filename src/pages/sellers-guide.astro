---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Seller's Guide | The Vogt Real Estate Group">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">For Sellers</span>
      <h1>Seller's Guide</h1>
      <p>
        Get the most value from your home sale with expert pricing,
        marketing, and negotiation from our experienced team.
      </p>
    </div>
  </section>

  <section>
    <div class="container" style="max-width: 780px;">
      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 1</span>
        <h3 style="margin: 0.75rem 0 1rem;">Get a Market Analysis</h3>
        <p style="color: var(--c-slate);">
          We provide a comprehensive comparative market analysis to determine
          the optimal listing price for your home. Our knowledge of Sacramento-area
          neighborhoods means you get pricing backed by real local data.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 2</span>
        <h3 style="margin: 0.75rem 0 1rem;">Prepare & Stage</h3>
        <p style="color: var(--c-slate);">
          First impressions matter. We'll advise on improvements, staging, and
          photography that highlight your home's best features and attract
          serious buyers.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 3</span>
        <h3 style="margin: 0.75rem 0 1rem;">Market Your Property</h3>
        <p style="color: var(--c-slate);">
          Your listing gets maximum exposure through MetroList MLS, professional
          photography, social media campaigns, open houses, and our network of
          active buyers and agents across the region.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 4</span>
        <h3 style="margin: 0.75rem 0 1rem;">Review Offers & Negotiate</h3>
        <p style="color: var(--c-slate);">
          We evaluate every offer on your behalf, comparing terms, contingencies,
          and buyer qualifications. Our 35+ years of negotiation experience means
          you get the best deal possible.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 5</span>
        <h3 style="margin: 0.75rem 0 1rem;">Close with Confidence</h3>
        <p style="color: var(--c-slate);">
          From accepted offer through escrow, inspections, disclosures, and
          final signing — we manage the details so you can move forward
          with peace of mind.
        </p>
      </div>

      <div class="fade-in" style="text-align: center; padding-top: 2rem;">
        <a href="/contact" class="btn btn-primary">Get Your Free Valuation</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
