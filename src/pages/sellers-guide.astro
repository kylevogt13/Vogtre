---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Seller's Guide | The Vogt Real Estate Group" description="A step-by-step guide to selling your home in Sacramento. Expert guidance from The Vogt Real Estate Group.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">A Step-by-Step Guide</span>
      <h1>Selling With Vogt Real Estate Group</h1>
    </div>
  </section>

  <section>
    <div class="container" style="max-width: 780px;">
      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 1</span>
        <h3 style="margin: 0.75rem 0 1rem;">Understand Why You're Selling</h3>
        <p style="color: var(--c-slate);">
          Each listing differs based on seller needs. We listen to what matters most and
          prepare a customized action plan. Communication is key to a successful transaction.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 2</span>
        <h3 style="margin: 0.75rem 0 1rem;">Determine Selling Price, Disclosures &amp; Listing Agreement</h3>
        <p style="color: var(--c-slate);">
          Proper pricing generates maximum buyer interest. Overpricing can lead to reduced
          interest and you lose peak marketing time. Greatest leverage in first 30 days.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 3</span>
        <h3 style="margin: 0.75rem 0 1rem;">Start Preparations</h3>
        <p style="color: var(--c-slate);">
          Pre-open title/escrow to uncover title problems early. Pre-listing inspections
          prevent unexpected surprises. Home staging: declutter, depersonalize, repair,
          deep clean.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 4</span>
        <h3 style="margin: 0.75rem 0 1rem;">Develop a Marketing Strategy</h3>
        <p style="color: var(--c-slate);">
          Drive the right people to your listing through social media, agent-to-agent
          referrals, traditional media, and SEO advertising. Innovative marketing
          outperforms outdated tactics.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 5</span>
        <h3 style="margin: 0.75rem 0 1rem;">Evaluate Offers</h3>
        <p style="color: var(--c-slate);">
          Evaluate each offer and confirm buyer pre-approval. Review purchase price,
          deposit, down payment, financing, contingencies, and settlement date.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 6</span>
        <h3 style="margin: 0.75rem 0 1rem;">Accept an Offer</h3>
        <p style="color: var(--c-slate);">
          Once both parties agree to terms, the purchase contract is signed.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 7</span>
        <h3 style="margin: 0.75rem 0 1rem;">During Escrow</h3>
        <p style="color: var(--c-slate);">
          Buyers conduct inspections and lenders order appraisals. Buyers acknowledge
          disclosures and remove contingencies.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <span class="overline">Step 8</span>
        <h3 style="margin: 0.75rem 0 1rem;">Closing</h3>
        <p style="color: var(--c-slate);">
          Ownership transfers to the buyer. Arrange utility cancellations and provide
          keys, remotes, and smart device instructions.
        </p>
      </div>

      <div class="fade-in" style="margin-bottom: 3rem;">
        <p style="color: var(--c-slate); font-style: italic;">
          Congratulations! You're free to take the next step in your journey.
        </p>
      </div>

      <div class="cta-band fade-in" style="text-align: center; padding-top: 2rem;">
        <a href="/contact" class="btn btn-primary">Get Your Free Valuation</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
