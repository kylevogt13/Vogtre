---

<BaseLayout title="Testimonials | The Vogt Real Estate Group" description="Read reviews from families and professionals who trust The Vogt Real Estate Group for buying and selling homes in Sacramento, Wilton, Fair Oaks, and Roseville.">
  <Nav />

  <section class="page-hero">
    <div class="container">
      <span class="overline">Client Reviews</span>
      <h1>Testimonials</h1>
      <p>
        Hear from the families and professionals who trust The Vogt
        Real Estate Group with their most important decisions.
      </p>
    </div>
  </section>

  <section>
    <div class="container" style="max-width: 800px;">
      {testimonials.map((t) => (
        <div class="testimonial-card fade-in" style="margin-bottom: 2rem;">
          <p>{t.quote}</p>
          <div class="testimonial-card__author">{t.name}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Ready to Experience the Difference?</h2>
      <p>Let's write your success story together.</p>
      <a href="/contact" class="btn btn-outline">Contact Us</a>
    </div>
  </section>

  <Footer />
</BaseLayout>
